.max-w-3xl.mx-auto.px-4.sm:px-6.lg:px-8.py-8
  .mb-6
    = link_to "← Back to projects",
              projects_path,
              class: "text-sm font-medium text-gray-500 hover:text-teal-700 transition"

  .rounded-2xl.border.border-gray-200.bg-white.shadow-sm
    .border-b.border-gray-200.px-6.py-5
      %p.text-sm.font-medium.text-teal-700
        New board

      %h1.mt-1.text-2xl.font-bold.text-gray-900
        Create project

      %p.mt-2.text-sm.text-gray-500
        Start a new Kanban board and organize related tasks in one place.

    .px-6.py-6
      = render "form", project: @project