.max-w-3xl.mx-auto.px-4.sm:px-6.lg:px-8.py-8
  .mb-6
    = link_to "← Back to project",
              project_path(@project),
              class: "text-sm font-medium text-gray-500 hover:text-teal-700 transition"

  .rounded-2xl.border.border-gray-200.bg-white.shadow-sm
    .border-b.border-gray-200.px-6.py-5
      %p.text-sm.font-medium.text-teal-700
        Project settings

      %h1.mt-1.text-2xl.font-bold.text-gray-900
        Edit project

      %p.mt-2.text-sm.text-gray-500
        Update the project name and description shown across the workspace.

    .px-6.py-6
      = render "form", project: @project

  .mt-6.rounded-2xl.border.border-red-200.bg-red-50.p-6
    %h2.text-lg.font-semibold.text-red-900
      Danger zone

    %p.mt-2.text-sm.text-red-700
      Deleting this project will permanently remove the project and all of its tasks.

    .mt-4
      = button_to "Delete project",
                  project_path(@project),
                  method: :delete,
                  data: { turbo_confirm: "Are you sure you want to delete this project and all its tasks?" },
                  class: "rounded-lg border border-red-300 bg-white px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-100 cursor-pointer transition"