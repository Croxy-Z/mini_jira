- to_do_tasks = @tasks_by_status.fetch("to_do", [])
- in_progress_tasks = @tasks_by_status.fetch("in_progress", [])
- done_tasks = @tasks_by_status.fetch("done", [])

-# Project header
.mb-8.rounded-2xl.border.border-gray-200.bg-white.p-6.shadow-sm
  .flex.flex-col.gap-5.lg:flex-row.lg:items-start.lg:justify-between
    %div.min-w-0
      %p.text-sm.font-medium.text-teal-700
        Kanban board

      %h1.mt-1.text-3xl.font-bold.text-gray-900.break-words
        = @project.title

      - if @project.description.present?
        %p.mt-2.max-w-3xl.text-sm.text-gray-600.leading-relaxed.break-words
          = @project.description

    .flex.flex-wrap.gap-3.shrink-0
      = link_to "Edit project",
                edit_project_path(@project),
                class: "inline-flex items-center rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 transition"

      = link_to "Back to projects",
                projects_path,
                class: "inline-flex items-center rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 transition"

-# Control panel
.mt-6.flex.flex-col.gap-4.border-t.border-gray-200.pt-5.sm:flex-row.sm:items-end.sm:justify-between
  %div
    %h2.text-lg.font-semibold.text-gray-900
      Workflow

    %p.mt-1.text-sm.text-gray-500
      Move tasks between columns or edit task details directly from the board.

  = link_to "Add Task",
              new_project_task_path(@project),
              data: { turbo_frame: "modal" },
              class: "inline-flex items-center justify-center rounded-lg bg-teal-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-teal-700 transition"

-# Kanban Board
.mt-5.grid.grid-cols-1.md:grid-cols-3.gap-6.items-start{ data: { controller: "board" } }

  -# Column 1: TO DO
  = render TaskColumnComponent.new(title: "To Do", status: "to_do", tasks: to_do_tasks, project: @project)

  -# Column 2: IN PROGRESS
  = render TaskColumnComponent.new(title: "In Progress", status: "in_progress", tasks: in_progress_tasks, project: @project)

  -# Column 3: DONE
  = render TaskColumnComponent.new(title: "Done", status: "done", tasks: done_tasks, project: @project)

= turbo_frame_tag "modal"