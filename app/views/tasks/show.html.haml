= turbo_frame_tag "modal" do
  %div{ class: "fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4" }
    .w-full.max-w-lg.rounded-xl.bg-white.shadow-xl.border.border-gray-200
      .flex.items-start.justify-between.border-b.border-gray-200.px-6.py-4
        %div.min-w-0
          %p.text-sm.font-medium.text-teal-700
            Task details

          %h1.mt-1.text-xl.font-bold.text-gray-900.break-words
            = @task.title

        = link_to "×",
                  project_path(@project),
                  data: { turbo_frame: "_top" },
                  class: "text-2xl leading-none text-gray-400 hover:text-gray-700 transition"

      .space-y-5.px-6.py-5
        .flex.items-center.gap-2
          %span.text-sm.font-medium.text-gray-500
            Status

          %span.rounded-full.bg-gray-100.px-3.py-1.text-xs.font-medium.text-gray-700
            = @task.status.humanize

        .space-y-2
          %h2.text-sm.font-semibold.text-gray-900
            Description

          - if @task.description.present?
            %p.text-sm.text-gray-600.leading-relaxed.break-words.whitespace-pre-line
              = @task.description
          - else
            %p.text-sm.text-gray-400
              No description provided.

      .flex.items-center.justify-between.gap-3.border-t.border-gray-200.px-6.py-4
        = button_to "Delete task",
                    project_task_path(@project, @task),
                    method: :delete,
                    data: { turbo_confirm: "Are you sure you want to delete this task?" },
                    class: "rounded-lg border border-red-200 px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-50 cursor-pointer transition"

        .flex.items-center.gap-3
          = link_to "Close",
                    project_path(@project),
                    data: { turbo_frame: "_top" },
                    class: "rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 transition"

          = link_to "Edit task",
                    edit_project_task_path(@project, @task),
                    data: { turbo_frame: "modal" },
                    class: "rounded-lg bg-teal-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-teal-700 transition"