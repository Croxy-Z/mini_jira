%div{ id: dom_id(task),
      class: "bg-white p-3 rounded shadow-sm border border-gray-200 cursor-grab hover:border-teal-500 hover:shadow transition-all",
      data: { task_id: task.id, move_url: move_project_task_path(project, task) } }
  .flex.items-start.justify-between.gap-3
    %p.min-w-0.text-sm.font-medium.text-gray-900.break-words
      = task.title

    = link_to 'Open',
          project_task_path(project, task),
          data: { turbo_frame: "modal" },
          class: "shrink-0 rounded-md px-2 py-1 text-xs font-medium text-gray-500 hover:bg-gray-100 hover:text-teal-700 transition"

  - if task.description.present?
    %p.mt-2.text-sm.text-gray-600.leading-relaxed.break-words.line-clamp-3
      = task.description