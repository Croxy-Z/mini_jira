= form_with(model: [@project, @task], class: "space-y-4") do |f|
  - if @task.errors.any?
    .rounded-md.bg-red-50.p-4.text-sm.text-red-700
      %p.font-medium
        = "#{pluralize(@task.errors.count, "error")} prohibited this task from being saved:"
      %ul.mt-2.list-disc.pl-5
        - @task.errors.full_messages.each do |message|
          %li= message

  %div
    = f.label :title, class: "block text-sm font-medium text-gray-700"
    = f.text_field :title, class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-teal-700 focus:outline-none focus:ring-1 focus:ring-teal-700"

  %div
    = f.label :description, class: "block text-sm font-medium text-gray-700"
    = f.text_area :description, rows: 4, class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-teal-700 focus:outline-none focus:ring-1 focus:ring-teal-700"

  - if @task.persisted?
    %div
      = f.label :status, class: "block text-sm font-medium text-gray-700"
      = f.select :status,
                 Task.statuses.keys.map { |status| [status.humanize, status] },
                 {},
                 class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-teal-700 focus:outline-none focus:ring-1 focus:ring-teal-700"

  %div.flex.justify-end.gap-3
    = link_to "Cancel",
              project_path(@project),
              data: { turbo_frame: "_top" },
              class: "rounded-md border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50"

    = f.submit class: "rounded-md bg-teal-700 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-teal-800 transition"