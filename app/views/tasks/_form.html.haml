= form_with(model: [@project, @task], class: "space-y-5") do |f|
  - if @task.errors.any?
    .rounded-lg.border.border-red-200.bg-red-50.p-4
      %h2.text-sm.font-semibold.text-red-800
        = "#{pluralize(@task.errors.count, "error")} prohibited this task from being saved:"

      %ul.mt-2.list-disc.space-y-1.pl-5.text-sm.text-red-700
        - @task.errors.full_messages.each do |message|
          %li= message

  .space-y-2
    = f.label :title, class: "block text-sm font-medium text-gray-700"
    = f.text_field :title,
                   class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-900 shadow-sm focus:border-teal-500 focus:ring-2 focus:ring-teal-500/20 focus:outline-none"

  .space-y-2
    = f.label :description, class: "block text-sm font-medium text-gray-700"
    = f.text_area :description,
                  rows: 4,
                  class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-900 shadow-sm focus:border-teal-500 focus:ring-2 focus:ring-teal-500/20 focus:outline-none"

  .flex.items-center.justify-end.gap-3.pt-2
    = link_to "Cancel",
              project_path(@project),
              data: { turbo_frame: "_top" },
              class: "rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 transition"

    = f.submit @task.persisted? ? "Update Task" : "Create Task",
               class: "rounded-lg bg-teal-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-teal-700 cursor-pointer transition"