.max-w-md.mx-auto.px-4.py-12
  .rounded-2xl.border.border-gray-200.bg-white.p-8.shadow-sm
    .text-center
      %p.text-sm.font-medium.text-teal-700
        Account recovery

      %h1.mt-2.text-3xl.font-bold.text-gray-900
        Forgot your password?

      %p.mt-2.text-sm.text-gray-500
        Enter your email address and we will send you instructions to reset your password.

    = form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "mt-6 space-y-5" }) do |f|
      = render "devise/shared/error_messages", resource: resource

      .space-y-2
        = f.label :email, class: "block text-sm font-medium text-gray-700"
        = f.email_field :email,
                        autofocus: true,
                        autocomplete: "email",
                        class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-900 shadow-sm focus:border-teal-500 focus:ring-2 focus:ring-teal-500/20 focus:outline-none"

      = f.submit "Send reset instructions",
                 class: "w-full rounded-lg bg-teal-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-teal-700 transition"

    .mt-6.border-t.border-gray-200.pt-5.text-center.text-sm.text-gray-500
      = render "devise/shared/links"