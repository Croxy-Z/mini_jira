.max-w-7xl.mx-auto.px-4.sm:px-6.lg:px-8.py-8
  .rounded-2xl.bg-gradient-to-r.from-teal-600.to-cyan-600.p-8.text-white.shadow-sm
    %p.text-sm.font-medium.text-teal-100
      Welcome back

    %h1.mt-2.text-3xl.font-bold
      Mini Jira Dashboard

    %p.mt-3.max-w-2xl.text-teal-50
      Track projects, manage tasks, and keep your Kanban workflow organized.

    .mt-6.flex.flex-wrap.gap-3
      = link_to "Open projects",
                projects_path,
                class: "inline-flex items-center rounded-lg bg-white px-4 py-2 text-sm font-semibold text-teal-700 shadow-sm hover:bg-teal-50 transition"

      = link_to "New project",
                new_project_path,
                class: "inline-flex items-center rounded-lg border border-white/40 px-4 py-2 text-sm font-semibold text-white hover:bg-white/10 transition"

  .mt-8.grid.grid-cols-1.gap-4.sm:grid-cols-3
    .rounded-xl.border.border-gray-200.bg-white.p-5.shadow-sm
      %p.text-sm.font-medium.text-gray-500
        Projects
      %p.mt-2.text-3xl.font-bold.text-gray-900
        = @projects_count

    .rounded-xl.border.border-gray-200.bg-white.p-5.shadow-sm
      %p.text-sm.font-medium.text-gray-500
        Tasks
      %p.mt-2.text-3xl.font-bold.text-gray-900
        = @tasks_count

    .rounded-xl.border.border-gray-200.bg-white.p-5.shadow-sm
      %p.text-sm.font-medium.text-gray-500
        Done tasks
      %p.mt-2.text-3xl.font-bold.text-emerald-600
        = @done_tasks_count

  .mt-8.rounded-xl.border.border-gray-200.bg-white.shadow-sm
    .flex.items-center.justify-between.border-b.border-gray-200.px-5.py-4
      %div
        %h2.text-lg.font-semibold.text-gray-900
          Recent projects
        %p.mt-1.text-sm.text-gray-500
          Continue working on your latest boards.

      = link_to "View all",
                projects_path,
                class: "text-sm font-medium text-teal-600 hover:text-teal-700"

    - if @recent_projects.any?
      .divide-y.divide-gray-100
        - @recent_projects.each do |project|
          = link_to project_path(project), class: "block px-5 py-4 hover:bg-gray-50 transition" do
            .flex.items-start.justify-between.gap-4
              %div.min-w-0.flex-1
                %h3.truncate.text-sm.font-semibold.text-gray-900{ title: project.title }
                  = project.title

                - if project.description.present?
                  %p.mt-1.line-clamp-2.text-sm.text-gray-600.break-words
                    = project.description

              %span.shrink-0.rounded-full.bg-gray-100.px-3.py-1.text-xs.font-medium.text-gray-600
                = pluralize(project.tasks.size, "task")
    - else
      .px-5.py-8.text-center
        %p.text-sm.text-gray-500
          No projects yet. Create your first Kanban board to get started.

        .mt-4
          = link_to "Create project",
                    new_project_path,
                    class: "inline-flex items-center rounded-lg bg-teal-600 px-4 py-2 text-sm font-semibold text-white hover:bg-teal-700 transition"