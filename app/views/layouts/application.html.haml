!!!
%html
  %head
    %meta{:content => "text/html; charset=UTF-8", "http-equiv" => "Content-Type"}/
    %title= content_for(:title) || "Mini Jira"
    %meta{:content => "width=device-width,initial-scale=1", :name => "viewport"}/
    %meta{:content => "yes", :name => "apple-mobile-web-app-capable"}/
    %meta{:content => "Mini Jira", :name => "application-name"}/
    %meta{:content => "yes", :name => "mobile-web-app-capable"}/
    = csrf_meta_tags
    = csp_meta_tag
    = yield :head
    %link{:href => "/icon.png", :rel => "icon", :type => "image/png"}/
    %link{:href => "/icon.svg", :rel => "icon", :type => "image/svg+xml"}/
    %link{:href => "/icon.png", :rel => "apple-touch-icon"}/
    = stylesheet_link_tag "tailwind", "data-turbo-track": "reload"
    = stylesheet_link_tag "application", "data-turbo-track": "reload"
    = javascript_importmap_tags

  %body.bg-gray-100.text-gray-900
    -# Notices and alerts
    - if notice
      .bg-green-100.text-green-800.p-4.text-center.font-medium= notice
    - if alert
      .bg-red-100.text-red-800.p-4.text-center.font-medium= alert

    -# Navbar
    %nav.bg-teal-800.text-white.shadow-md.mb-8
      .max-w-7xl.mx-auto.px-4.sm:px-6.lg:px-8
        .flex.justify-between.h-16
          .flex.items-center
            = link_to "Mini Jira", root_path, class: "text-xl font-bold tracking-tight hover:text-teal-200"
          .flex.items-center.space-x-4
            - if user_signed_in?
              %span.text-sm.opacity-80= current_user.email
              = button_to "Sign out", destroy_user_session_path, method: :delete, class: "bg-teal-700 hover:bg-teal-900 px-4 py-2 rounded-md text-sm font-medium transition cursor-pointer"
            - else
              = link_to "Log in", new_user_session_path, class: "text-sm font-medium hover:text-teal-200"
              = link_to "Sign up", new_user_registration_path, class: "bg-white text-teal-600 hover:bg-gray-50 px-4 py-2 rounded-md text-sm font-medium transition"

    %main.max-w-7xl.mx-auto.px-4.sm:px-6.lg:px-8
      = yield