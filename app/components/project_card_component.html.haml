%div{ id: "#{dom_id @project}", class: "h-full bg-white overflow-hidden shadow-sm rounded-lg border border-gray-200 hover:shadow-md transition-shadow duration-200" }
  .flex.h-full.flex-col.p-6
    %h2.text-xl.font-semibold.text-gray-900.mb-2.truncate
      = link_to @project.title,
                @project,
                title: @project.title,
                class: "hover:text-teal-600 transition"

    - if @project.description.present?
      %p.text-gray-600.text-sm.mb-4.line-clamp-2.break-words
        = @project.description
    - else
      %p.text-gray-600.text-sm.mb-4.min-h-10

    .mt-auto.flex.items-center.justify-between.border-t.border-gray-100.pt-4
      .text-xs.text-gray-500
        = "Created #{created_date}"

      = link_to "Open",
                project_path(@project),
                class: "text-sm font-medium text-teal-600 hover:text-teal-700"