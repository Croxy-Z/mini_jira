%div{ id: "#{dom_id @project}", class: "bg-white overflow-hidden shadow-sm rounded-lg border border-gray-200 hover:shadow-md transition-shadow duration-200" }
  .p-6
    %h2.text-xl.font-semibold.text-gray-900.mb-2.truncate
      = link_to @project.title, @project, class: "hover:text-teal-600 transition"

    - if @project.description.present?
      %p.text-gray-600.text-sm.mb-4.line-clamp-2
        = @project.description

    .flex.items-center.justify-between.mt-4.pt-4.border-t.border-gray-100
      .text-xs.text-gray-500
        = "Created #{created_date}"
      .flex.space-x-2
        = link_to "Edit", edit_project_path(@project), class: "text-sm text-gray-500 hover:text-teal-600"
        = link_to "Delete", @project, method: :delete, data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' }, class: "text-sm text-red-500 hover:text-red-700"